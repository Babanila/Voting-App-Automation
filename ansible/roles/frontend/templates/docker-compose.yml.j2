version: '3.8'

services:
  vote:
    image: {{ frontend_vote_image }}
    ports:
      - "8081:80"
    environment:
      REDIS_HOST: {{ redis_host }}
    restart: always

  result:
    image: {{ frontend_result_image }}
    ports:
      - "8080:80"
    environment:
      DB_HOST: {{ db_host }}
      DB_NAME: {{ db_name }}
      DB_USER: {{ db_user }}
      DB_PASSWORD: {{ db_password }}
    restart: always
